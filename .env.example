# Required: Anthropic API key for Claude vision
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: model override. Defaults to claude-3-5-sonnet-latest.
# CLAUDE_MODEL=claude-3-5-sonnet-latest

# Optional: set to "1" to run without the Anthropic API and return a
# canned demo response. Useful for screenshots and local UI work.
# DEMO_MODE=0
